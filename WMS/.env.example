APP_NAME=WMS
NEXT_PUBLIC_APP_NAME=WMS
NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/wms?schema=public&sslmode=disable

AUTH_PROVIDER=mock
NEXT_PUBLIC_AUTH_PROVIDER=mock
ENABLE_DEBUG_AUTH_ROUTES=false
NEXT_PUBLIC_ENABLE_DEBUG_AUTH_ROUTES=false
NEXT_PUBLIC_ENABLE_LDAP_DEBUG=false

EPS_API_BASE_URL=http://127.0.0.1:3100/api
EPS_API_TOKEN=
EPS_API_TIMEOUT_MS=10000

MMS_API_BASE_URL=http://127.0.0.1:3001/api
MMS_API_TIMEOUT_MS=10000
WMS_API_TOKEN=

WRITE_RATE_LIMIT=90
WRITE_RATE_WINDOW_MS=60000
